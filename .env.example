# OM Intelligence - Environment Variables

# =============================================
# NOTION INTEGRATION (Required for Deal Intake)
# =============================================

# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxx

# Database ID from your Deal Intake database URL
# https://www.notion.so/workspace/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX?v=...
#                                      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook secret for verifying incoming webhooks (generate a random string)
NOTION_WEBHOOK_SECRET=your-webhook-secret-key

# Your webhook URL (for n8n/Make.com to call)
NOTION_WEBHOOK_URL=https://your-api.com/api/notion/webhook

# =============================================
# API CONFIGURATION
# =============================================

# Base URL for generating analysis links
API_BASE_URL=https://your-frontend.com

# =============================================
# DATABASE (PostgreSQL)
# =============================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=om_intelligence
DB_USER=om_user
DB_PASSWORD=your-db-password

# =============================================
# FILE UPLOADS
# =============================================

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# =============================================
# LLM PROVIDERS
# =============================================

ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# Model selection
LLM_MODEL_HAIKU=claude-3-haiku-20240307
LLM_MODEL_STANDARD=claude-3-5-sonnet-20241022
LLM_MODEL_PREMIUM=claude-3-opus-20240229
PRICE_THRESHOLD_PREMIUM=5000000

# =============================================
# CHUNKING CONFIGURATION
# =============================================

CHUNK_SIZE=4000
CHUNK_OVERLAP=500
MAX_CHUNKS_PER_REQUEST=10

# =============================================
# REDIS (Optional - for job queues)
# =============================================

REDIS_URL=redis://localhost:6379
