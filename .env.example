ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Dropbox — create an app at https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_REDIRECT_URI=https://your-app.railway.app/api/dropbox/callback

# Postgres — Railway provides this automatically when you add a Postgres addon
DATABASE_URL=postgresql://user:password@host:5432/railway

# File storage
UPLOAD_DIR=./uploads

# Proforma engine URL (set after deploying proforma-engine service to Railway)
PROFORMA_ENGINE_URL=https://your-proforma-engine.railway.app
